{
  "name": "@type-arena/ws-server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/bundle.js --external:@prisma/client",
    "start": "node dist/bundle.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "@type-arena/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^4",
    "jsonwebtoken": "^9",
    "ws": "^8",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9",
    "@types/node": "^20",
    "@types/ws": "^8",
    "esbuild": "^0.27.4",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
